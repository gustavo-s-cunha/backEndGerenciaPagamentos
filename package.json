{
  "name": "gen-payment-backend",
  "version": "1.0.0",
  "scripts": {
    "dev": "ts-node src/server.ts",
    "build": "rm -rf ./dist && tsup src/server.ts --format cjs --clean --outDir dist",
    "start": "node ./dist/server.js",
    "test": "jest --detectOpenHandles --runInBand",
    "up": "npm run build && docker-compose up",
    "down": "docker-compose down",
    "migrate": "node -r ts-node/register ./node_modules/knex/bin/cli.js migrate:latest --env development"
  },
  "dependencies": {
    "@jest/test-sequencer": "^30.3.0",
    "@vinejs/compiler": "^4.1.3",
    "@vinejs/vine": "^1.0.0",
    "axios": "^1.6.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.0.0",
    "mysql2": "^3.9.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/uuid": "^10.0.0",
    "cross-env": "^10.1.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
